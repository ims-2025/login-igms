# --- Database (Vercel + Neon) ---
# These two vars are auto-injected by Vercel when you attach a Neon database
# to the project. For local dev, run `vercel env pull .env` to populate them.
POSTGRES_PRISMA_URL="postgres://user:pass@host/db?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://user:pass@host/db?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
# Public URL — in prod set to https://login.igms.me
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- Resend (magic-link email for clients) ---
# Sign up at resend.com, verify igms.me, then create an API key.
RESEND_API_KEY=""
AUTH_RESEND_FROM="IGMS Workspace <noreply@igms.me>"

# --- Initial admin (used by seed script) ---
SEED_ADMIN_EMAIL="onlineprojects@pm.me"
SEED_ADMIN_NAME="Chris"
SEED_ADMIN_PASSWORD="change-me-on-first-login"

# --- Confluence Cloud import (only needed when running scripts/import-confluence.ts) ---
# DO NOT commit the API token. Generate it at
# https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_BASE_URL="https://igamingmanagedservices.atlassian.net"
CONFLUENCE_EMAIL="onlineprojects@pm.me"
CONFLUENCE_API_TOKEN=""
# Optional: limit the import to one space key (e.g. "AFF") for testing.
# Leave blank to import every space the token can read.
CONFLUENCE_SPACE_KEY=""
# Set to "true" for a dry-run that lists spaces + page counts without writing.
CONFLUENCE_DRY_RUN="false"
